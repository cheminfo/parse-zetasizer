{
  "name": "parse-zetasizer",
  "version": "1.1.0",
  "license": "MIT",
  "description": "Parse text exports from Malvern Panalytical Zetasizer instruments",
  "keywords": [
    "zetasizer",
    "malvern",
    "panalytical",
    "DLS",
    "dynamic light scattering",
    "particle size",
    "parser"
  ],
  "author": "Luc Patiny",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf coverage lib",
    "eslint": "eslint .",
    "eslint-fix": "eslint . --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "dynamic-typing": "^2.0.0",
    "ensure-string": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@zakodium/tsconfig": "^1.0.2",
    "eslint": "^9.39.3",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/parse-zetasizer.git"
  },
  "bugs": {
    "url": "https://github.com/cheminfo/parse-zetasizer/issues"
  },
  "homepage": "https://github.com/cheminfo/parse-zetasizer#readme"
}
